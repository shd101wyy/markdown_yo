// markdown_yo — Main parser orchestrator
//
// Top-level API: normalize → block parse → HTML output.
// SAX-style: block parser calls renderer directly, inline parser uses
// lightweight InlineToken buffer then flushes to renderer.

open import "std/string";
{ ArrayList } :: import "std/collections/array_list";
{ Options, Env, new_env } :: import "./types.yo";
{ HtmlRenderer } :: import "./renderer.yo";
{ BlockState } :: import "./block/state.yo";
{ block_parse } :: import "./block/parser.yo";

// Convert markdown source to HTML.
markdown_to_html :: (fn(src: String, options: *(Options)) -> String)({
  // 1. Create environment for link references
  (env : Env) = new_env();

  // 2. Get source pointer
  (src_bytes : ArrayList(u8)) = src.as_bytes();
  (src_len : i32) = i32(src_bytes.len());
  (src_ptr : *(u8)) = match(src_bytes.ptr(),
    .Some(p) => p,
    .None => *(u8)("")
  );

  // 3. Create renderer with pre-allocated output buffer
  (renderer : HtmlRenderer) = HtmlRenderer.new(options, src_ptr, src_len);

  // 4. Create block state (includes normalization + line scan in one pass)
  (state : BlockState) = BlockState.new(src, env, (&renderer), options);
  block_parse((&state));

  // 5. Return rendered HTML
  renderer.finish()
});

export markdown_to_html;
