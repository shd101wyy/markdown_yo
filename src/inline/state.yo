// markdown_yo — Inline parser state
//
// Tracks position, delimiters, and inline tokens during inline parsing.

open import "std/string";
{ ArrayList } :: import "std/collections/array_list";
{ HashMap } :: import "std/collections/hash_map";
{ GlobalAllocator } :: import "std/allocator";
{ calloc, free } :: GlobalAllocator;
{ memset } :: import "std/libc/string.yo";
{ Options, Env, Delimiter, InlineType, LinkMarker, EmphasisPair } :: import "../types.yo";
{ HtmlRenderer } :: import "../renderer.yo";
{ is_space } :: import "../common/utils.yo";

// Lightweight inline token — pure value type, no RC fields
// String content (entities, resolved URLs) stored separately in InlineState.token_strings
InlineToken :: struct(
  type_name : InlineType,
  start : i32,          // byte offset in source
  end : i32,            // byte offset in source
  nesting : i32,        // -1, 0, 1
  level : i32,
  // Extra fields for links/images
  info_start : i32,     // href/src start
  info_end : i32,       // href/src end
  title_start : i32,    // title start
  title_end : i32,      // title end
  markup_char : u8,     // '*', '_', '~', '`'
  markup_len : u8,      // number of marker chars
  block : bool,
  hidden : bool,
  // Indices into InlineState.token_strings (-1 = none)
  content_idx : i32,
  href_idx : i32,
  title_idx : i32
);

impl(InlineToken,
  text : (fn(start: i32, end: i32, level: i32) -> Self)(
    Self(type_name: .Text, start: start, end: end, nesting: i32(0), level: level,
         info_start: i32(0), info_end: i32(0), title_start: i32(0), title_end: i32(0),
         markup_char: u8(0), markup_len: u8(0), block: false, hidden: false,
         content_idx: i32(-1), href_idx: i32(-1), title_idx: i32(-1))
  ),
  text_special : (fn(start: i32, end: i32, level: i32) -> Self)(
    Self(type_name: .TextSpecial, start: start, end: end, nesting: i32(0), level: level,
         info_start: i32(0), info_end: i32(0), title_start: i32(0), title_end: i32(0),
         markup_char: u8(0), markup_len: u8(0), block: false, hidden: false,
         content_idx: i32(-1), href_idx: i32(-1), title_idx: i32(-1))
  ),
  simple : (fn(type_name: InlineType, nesting: i32, level: i32) -> Self)(
    Self(type_name: type_name, start: i32(0), end: i32(0), nesting: nesting, level: level,
         info_start: i32(0), info_end: i32(0), title_start: i32(0), title_end: i32(0),
         markup_char: u8(0), markup_len: u8(0), block: false, hidden: false,
         content_idx: i32(-1), href_idx: i32(-1), title_idx: i32(-1))
  )
);

// Initialize a 256-byte lookup table for inline special characters.
// Returns a *(u8) where table[ch] != 0 means ch is special.
_init_special_table :: (fn() -> *(u8))({
  (ptr : *(u8)) = match(calloc(usize(256), usize(1)),
    .Some(p) => *(u8)(p),
    .None => { assert(false, "calloc failed"); *(u8)("") }
  );
  // 0x0A = newline, 0x21 = !, 0x26 = &, 0x2A = *
  // 0x3C = <, 0x5B = [, 0x5C = \, 0x5D = ]
  // 0x5F = _, 0x60 = `, 0x7E = ~
  (ptr &+ usize(0x0A)).* = u8(1);
  (ptr &+ usize(0x21)).* = u8(1);
  (ptr &+ usize(0x26)).* = u8(1);
  (ptr &+ usize(0x2A)).* = u8(1);
  (ptr &+ usize(0x3C)).* = u8(1);
  (ptr &+ usize(0x5B)).* = u8(1);
  (ptr &+ usize(0x5C)).* = u8(1);
  (ptr &+ usize(0x5D)).* = u8(1);
  (ptr &+ usize(0x5F)).* = u8(1);
  (ptr &+ usize(0x60)).* = u8(1);
  (ptr &+ usize(0x7E)).* = u8(1);
  ptr
});

InlineState :: struct(
  src : Option(String),      // inline content string (None for range-based parsing)
  src_ptr : *(u8),         // raw pointer for fast access
  pos : i32,               // current position in source
  pos_max : i32,           // source length

  level : i32,             // nesting level
  pending_start : i32,     // start of pending text (byte offset)
  pending_end : i32,       // end of pending text

  tokens : ArrayList(InlineToken),
  delimiters : ArrayList(Delimiter),
  prev_delimiters : ArrayList(ArrayList(Delimiter)),

  cache : Option(HashMap(i32, i32)),        // backtrack positions (lazy)
  backticks : Option(HashMap(i32, i32)),    // backtick length → last seen position (lazy)
  backticks_scanned : bool,

  link_level : i32,
  link_markers : ArrayList(LinkMarker),
  resolved_pairs : ArrayList(EmphasisPair),

  // Side storage for token strings (content/href/title)
  // Tokens reference these by index (content_idx/href_idx/title_idx)
  token_strings : ArrayList(String),

  env : *(Env),
  renderer : *(HtmlRenderer),
  options : *(Options),

  // 256-byte lookup table: table[ch] != 0 means ch is an inline special character
  special_table : *(u8)
);

impl(InlineState,
  // Create a reusable state with pre-allocated buffers
  reusable : (fn(env: *(Env), renderer: *(HtmlRenderer), options: *(Options)) -> Self)(
    Self(
      src: .None,
      src_ptr: *(u8)(""),
      pos: i32(0),
      pos_max: i32(0),
      level: i32(0),
      pending_start: i32(0),
      pending_end: i32(0),
      tokens: ArrayList(InlineToken).with_capacity(usize(32)),
      delimiters: ArrayList(Delimiter).with_capacity(usize(16)),
      prev_delimiters: ArrayList(ArrayList(Delimiter)).new(),
      cache: .None,
      backticks: .None,
      backticks_scanned: false,
      link_level: i32(0),
      link_markers: ArrayList(LinkMarker).with_capacity(usize(8)),
      resolved_pairs: ArrayList(EmphasisPair).with_capacity(usize(8)),
      token_strings: ArrayList(String).with_capacity(usize(4)),
      env: env,
      renderer: renderer,
      options: options,
      special_table: _init_special_table()
    )
  ),

  // Store a string in token_strings and return its index
  store_string : (fn(self: *(Self), s: String) -> i32)({
    (idx : i32) = i32(self.*.token_strings.len());
    _ := self.*.token_strings.push(s);
    idx
  }),

  // Get a stored string by index (returns a copy)
  get_string : (fn(self: *(Self), idx: i32) -> String)(
    self.*.token_strings(usize(idx))
  ),

  // Reset for range-based (zero-copy) parsing. Clears lists but keeps allocated capacity.
  reset_for_ptr : (fn(self: *(Self), ptr: *(u8), len: i32) -> unit)({
    self.*.tokens.clear();
    self.*.delimiters.clear();
    self.*.prev_delimiters.clear();
    self.*.link_markers.clear();
    self.*.resolved_pairs.clear();
    self.*.token_strings.clear();
    self.*.src = .None;
    self.*.src_ptr = ptr;
    self.*.pos = i32(0);
    self.*.pos_max = len;
    self.*.level = i32(0);
    self.*.pending_start = i32(0);
    self.*.pending_end = i32(0);
    self.*.link_level = i32(0);
    self.*.cache = .None;
    self.*.backticks = .None;
    self.*.backticks_scanned = false;
  }),

  // Reset for string-based parsing. Clears lists but keeps allocated capacity.
  reset_for_string : (fn(self: *(Self), src: String) -> unit)({
    self.*.tokens.clear();
    self.*.delimiters.clear();
    self.*.prev_delimiters.clear();
    self.*.link_markers.clear();
    self.*.resolved_pairs.clear();
    self.*.token_strings.clear();
    (bytes : ArrayList(u8)) = src.as_bytes();
    (len : i32) = i32(bytes.len());
    (src_p : *(u8)) = match(bytes.ptr(),
      .Some(p) => p,
      .None => *(u8)("")
    );
    self.*.src = .Some(src);
    self.*.src_ptr = src_p;
    self.*.pos = i32(0);
    self.*.pos_max = len;
    self.*.level = i32(0);
    self.*.pending_start = i32(0);
    self.*.pending_end = i32(0);
    self.*.link_level = i32(0);
    self.*.cache = .None;
    self.*.backticks = .None;
    self.*.backticks_scanned = false;
  }),

  // Push pending text as a token if there's any accumulated
  push_pending : (fn(self: *(Self)) -> unit)({
    if((self.*.pending_end > self.*.pending_start), {
      (tok : InlineToken) = InlineToken.text(self.*.pending_start, self.*.pending_end, self.*.level);
      _ := self.*.tokens.push(tok);
    });
    self.*.pending_start = self.*.pos;
    self.*.pending_end = self.*.pos;
  }),

  // Get byte at current position (or -1 if at end)
  char_at : (fn(self: *(Self), pos: i32) -> i32)(
    cond(
      ((pos < i32(0)) || (pos >= self.*.pos_max)) => i32(-1),
      true => i32((self.*.src_ptr &+ usize(pos)).*)
    )
  )
);

export InlineToken, InlineState;
