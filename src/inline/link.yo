// markdown_yo — Inline link rule
//
// Two-phase approach matching markdown-it:
// 1. inline_link_open: when [ or ![ is seen, push a bracket marker
// 2. inline_link_close: when ] is seen, try to resolve as link/image

open import "std/string";
{ ArrayList } :: import "std/collections/array_list";
{ InlineState, InlineToken } :: import "./state.yo";
{ InlineType, Reference, LinkMarker, Delimiter, EmphasisPair } :: import "../types.yo";
{ is_space } :: import "../common/utils.yo";
{ try_decode_entity } :: import "../common/unescape.yo";

// Check if a byte is ASCII alpha
_is_alpha :: (fn(b: u8) -> bool)(
  (((b >= u8(0x41)) && (b <= u8(0x5A))) || ((b >= u8(0x61)) && (b <= u8(0x7A))))
);

// Convert byte to lowercase ASCII
_to_lower :: (fn(b: u8) -> u8)(
  cond(
    ((b >= u8(0x41)) && (b <= u8(0x5A))) => (b + u8(0x20)),
    true => b
  )
);

// Check if protocol is blocked. buf/len is the decoded URL prefix.
_check_protocol :: (fn(buf: *(u8), buf_len: i32) -> bool)({
  if((buf_len <= i32(0)), { return true; });

  // Find the colon position (protocol separator)
  (colon_pos : i32) = i32(-1);
  (i : i32) = i32(0);
  while ((i < buf_len) && (i < i32(25))), {
    (b : u8) = (buf &+ usize(i)).*;
    if((b == u8(0x3A)), {
      colon_pos = i;
      i = buf_len; // break
    }, {
      if(!(_is_alpha(b)), {
        return true;
      });
    });
    i = (i + i32(1));
  };

  if((colon_pos < i32(0)), { return true; });

  // Helper: compare lowercase protocol bytes against a known pattern
  // javascript: (10 chars)
  if((colon_pos == i32(10)), {
    if(((_to_lower((buf &+ usize(0)).*) == u8(0x6A))
     && (_to_lower((buf &+ usize(1)).*) == u8(0x61))), {
      if(((_to_lower((buf &+ usize(2)).*) == u8(0x76))
       && (_to_lower((buf &+ usize(3)).*) == u8(0x61))), {
        if(((_to_lower((buf &+ usize(4)).*) == u8(0x73))
         && (_to_lower((buf &+ usize(5)).*) == u8(0x63))), {
          if(((_to_lower((buf &+ usize(6)).*) == u8(0x72))
           && (_to_lower((buf &+ usize(7)).*) == u8(0x69))), {
            if(((_to_lower((buf &+ usize(8)).*) == u8(0x70))
             && (_to_lower((buf &+ usize(9)).*) == u8(0x74))), {
              return false;
            });
          });
        });
      });
    });
  });

  // vbscript: (8 chars)
  if((colon_pos == i32(8)), {
    if(((_to_lower((buf &+ usize(0)).*) == u8(0x76))
     && (_to_lower((buf &+ usize(1)).*) == u8(0x62))), {
      if(((_to_lower((buf &+ usize(2)).*) == u8(0x73))
       && (_to_lower((buf &+ usize(3)).*) == u8(0x63))), {
        if(((_to_lower((buf &+ usize(4)).*) == u8(0x72))
         && (_to_lower((buf &+ usize(5)).*) == u8(0x69))), {
          if(((_to_lower((buf &+ usize(6)).*) == u8(0x70))
           && (_to_lower((buf &+ usize(7)).*) == u8(0x74))), {
            return false;
          });
        });
      });
    });
  });

  // file: (4 chars)
  if((colon_pos == i32(4)), {
    if(((_to_lower((buf &+ usize(0)).*) == u8(0x66))
     && (_to_lower((buf &+ usize(1)).*) == u8(0x69))), {
      if(((_to_lower((buf &+ usize(2)).*) == u8(0x6C))
       && (_to_lower((buf &+ usize(3)).*) == u8(0x65))), {
        return false;
      });
    });
  });

  // data: (4 chars) — block unless data:image/
  if((colon_pos == i32(4)), {
    if(((_to_lower((buf &+ usize(0)).*) == u8(0x64))
     && (_to_lower((buf &+ usize(1)).*) == u8(0x61))), {
      if(((_to_lower((buf &+ usize(2)).*) == u8(0x74))
       && (_to_lower((buf &+ usize(3)).*) == u8(0x61))), {
        // Allow data:image/ (11+ decoded bytes)
        if((buf_len >= i32(11)), {
          if(((_to_lower((buf &+ usize(5)).*) == u8(0x69))
           && (_to_lower((buf &+ usize(6)).*) == u8(0x6D))), {
            if(((_to_lower((buf &+ usize(7)).*) == u8(0x61))
             && (_to_lower((buf &+ usize(8)).*) == u8(0x67))), {
              if(((_to_lower((buf &+ usize(9)).*) == u8(0x65))
               && ((buf &+ usize(10)).* == u8(0x2F))), {
                return true;
              });
            });
          });
        });
        return false;
      });
    });
  });

  true
});

// Validate a link URL — reject javascript:, vbscript:, file:, data: (except data:image/)
// Decodes HTML entities first to prevent protocol obfuscation (e.g. &#74;avascript:)
validate_link_url :: (fn(src: *(u8), start: i32, end_pos: i32) -> bool)({
  (len : i32) = (end_pos - start);
  if((len <= i32(0)), { return true; });

  // Decode entities in the URL prefix (only need ~32 decoded bytes for protocol check)
  (decoded : ArrayList(u8)) = ArrayList(u8).with_capacity(usize(32));
  (i : i32) = start;
  (max : i32) = cond(
    ((start + i32(64)) < end_pos) => (start + i32(64)),
    true => end_pos
  );
  while ((i < max) && (i32(decoded.len()) < i32(32))), {
    (b : u8) = (src &+ usize(i)).*;
    if((b == u8(0x26)), {
      (decoded_end : i32) = try_decode_entity(src, i, end_pos, &decoded);
      if((decoded_end > i32(0)), {
        i = decoded_end;
      }, {
        _ := decoded.push(b);
        i = (i + i32(1));
      });
    }, {
      _ := decoded.push(b);
      i = (i + i32(1));
    });
  };

  (result : bool) = cond(
    (decoded.len() == usize(0)) => true,
    true => _check_protocol(decoded.get_ptr(usize(0)), i32(decoded.len()))
  );
  decoded.dispose();
  result
});

// Parse link destination: either <...> or a bare URL
// Returns end position or -1 on failure
_parse_link_dest :: (fn(src: *(u8), start: i32, max: i32) -> i32)({
  (pos : i32) = start;
  if((pos >= max), { return i32(-1); });

  (ch : i32) = i32((src &+ usize(pos)).*);
  if((ch == i32(0x3C)), {
    // <...> form
    pos = (pos + i32(1));
    (found : bool) = false;
    while ((pos < max) && !(found)), {
      (c : i32) = i32((src &+ usize(pos)).*);
      if(((c == i32(0x0A)) || (c == i32(0x3C))), { return i32(-1); });
      if((c == i32(0x3E)), {
        found = true;
      }, {
        if((c == i32(0x5C)), {
          pos = (pos + i32(1));
          if((pos >= max), { return i32(-1); });
        });
        pos = (pos + i32(1));
      });
    };
    if(!(found), { return i32(-1); });
    (pos + i32(1))
  }, {
    // Bare URL: no spaces/newlines, balanced parens
    (level : i32) = i32(0);
    (done : bool) = false;
    while ((pos < max) && !(done)), {
      (c : i32) = i32((src &+ usize(pos)).*);
      if((is_space(c) || (c == i32(0x0A))), {
        done = true;
      }, {
        if((c == i32(0x28)), {
          level = (level + i32(1));
          if((level > i32(32)), { return i32(-1); });
        }, {
          if((c == i32(0x29)), {
            if((level <= i32(0)), {
              done = true;
            }, {
              level = (level - i32(1));
            });
          }, {
            if((c == i32(0x5C)), {
              // Don't let backslash escape spaces in link destinations
              if((((pos + i32(1)) < max) && (i32((src &+ usize((pos + i32(1)))).*) == i32(0x20))), {
                done = true;
              }, {
                pos = (pos + i32(1));
                if((pos >= max), { return i32(-1); });
              });
            });
          });
        });
        if(!(done), { pos = (pos + i32(1)); });
      });
    };
    if((level != i32(0)), { return i32(-1); });
    pos
  })
});

// Parse link title: "...", '...', or (...)
// Returns end position (after closing quote) or -1
_parse_link_title :: (fn(src: *(u8), start: i32, max: i32) -> i32)({
  (pos : i32) = start;
  if((pos >= max), { return i32(-1); });

  (marker : i32) = i32((src &+ usize(pos)).*);
  if(((marker != i32(0x22)) && ((marker != i32(0x27)) && (marker != i32(0x28)))), { return i32(-1); });

  (close_marker : i32) = cond(
    (marker == i32(0x28)) => i32(0x29),
    true => marker
  );

  pos = (pos + i32(1));
  (found : bool) = false;
  while ((pos < max) && !(found)), {
    (c : i32) = i32((src &+ usize(pos)).*);
    if((c == close_marker), {
      found = true;
    }, {
      // Opening paren inside (...) title is not allowed (even unescaped)
      if(((marker == i32(0x28)) && (c == i32(0x28))), { return i32(-1); });
      if((c == i32(0x5C)), {
        pos = (pos + i32(1));
      });
    });
    pos = (pos + i32(1));
  };
  if(!(found), { return i32(-1); });
  pos
});

// Find matching ] for an opening [ starting at pos
_find_close_bracket :: (fn(src: *(u8), start: i32, max: i32) -> i32)({
  (pos : i32) = start;
  (level : i32) = i32(1);
  while ((pos < max) && (level > i32(0))), {
    (c : i32) = i32((src &+ usize(pos)).*);
    if((c == i32(0x5C)), {
      pos = (pos + i32(2));
    }, {
      if((c == i32(0x5B)), {
        level = (level + i32(1));
        pos = (pos + i32(1));
      }, {
        if((c == i32(0x5D)), {
          level = (level - i32(1));
          if((level > i32(0)), { pos = (pos + i32(1)); });
        }, {
          pos = (pos + i32(1));
        });
      });
    });
  };
  if((level == i32(0)), pos, i32(-1))
});

// Normalize a reference label: trim, collapse whitespace, lowercase ASCII
_normalize_label :: (fn(src: *(u8), start: i32, end: i32) -> String)({
  (result : ArrayList(u8)) = ArrayList(u8).new();
  (p : i32) = start;
  (last_was_space : bool) = true;

  while (p < end), {
    (b : u8) = (src &+ usize(p)).*;
    (ch_byte : i32) = i32(b);
    if((is_space(ch_byte) || (ch_byte == i32(0x0A))), {
      if(!(last_was_space), {
        _ := result.push(u8(0x20));
        last_was_space = true;
      });
      p = (p + i32(1));
    }, {
      last_was_space = false;
      // Decode UTF-8 to get codepoint
      (cp : i32) = i32(0);
      (bytes_consumed : i32) = i32(1);
      if((ch_byte < i32(0x80)), {
        cp = ch_byte;
      }, if(((ch_byte >= i32(0xC0)) && (ch_byte < i32(0xE0))), {
        if(((p + i32(1)) < end), {
          cp = (((ch_byte - i32(0xC0)) * i32(64)) + (i32((src &+ usize((p + i32(1)))).*) - i32(0x80)));
          bytes_consumed = i32(2);
        }, { cp = ch_byte; });
      }, if(((ch_byte >= i32(0xE0)) && (ch_byte < i32(0xF0))), {
        if(((p + i32(2)) < end), {
          cp = ((((ch_byte - i32(0xE0)) * i32(4096)) + ((i32((src &+ usize((p + i32(1)))).*) - i32(0x80)) * i32(64))) + (i32((src &+ usize((p + i32(2)))).*) - i32(0x80)));
          bytes_consumed = i32(3);
        }, { cp = ch_byte; });
      }, if(((ch_byte >= i32(0xF0)) && (ch_byte < i32(0xF8))), {
        if(((p + i32(3)) < end), {
          cp = (((((ch_byte - i32(0xF0)) * i32(262144)) + ((i32((src &+ usize((p + i32(1)))).*) - i32(0x80)) * i32(4096))) + ((i32((src &+ usize((p + i32(2)))).*) - i32(0x80)) * i32(64))) + (i32((src &+ usize((p + i32(3)))).*) - i32(0x80)));
          bytes_consumed = i32(4);
        }, { cp = ch_byte; });
      }, { cp = ch_byte; }))));

      p = (p + bytes_consumed);

      // Multi-char expansions
      if((cp == i32(0x130)), {
        // İ → I + combining dot above (0x49 + 0x0307)
        _ := result.push(u8(0x49));
        _ := result.push(u8(0xCC));
        _ := result.push(u8(0x87));
      }, if((cp == i32(0xDF)), {
        _ := result.push(u8(0x53));
        _ := result.push(u8(0x53));
      }, if((cp == i32(0x1E9E)), {
        _ := result.push(u8(0x53));
        _ := result.push(u8(0x53));
      }, if((cp == i32(0xFB00)), {
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x46));
      }, if((cp == i32(0xFB01)), {
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x49));
      }, if((cp == i32(0xFB02)), {
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x4C));
      }, if((cp == i32(0xFB03)), {
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x49));
      }, if((cp == i32(0xFB04)), {
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x46));
        _ := result.push(u8(0x4C));
      }, if((cp == i32(0xFB05)), {
        _ := result.push(u8(0x53));
        _ := result.push(u8(0x54));
      }, if((cp == i32(0xFB06)), {
        _ := result.push(u8(0x53));
        _ := result.push(u8(0x54));
      }, {
        // Single-char case mappings
        (upper : i32) = cond(
          ((cp >= i32(0x61)) && (cp <= i32(0x7A))) => (cp - i32(0x20)),
          ((cp >= i32(0xE0)) && (cp <= i32(0xF6))) => (cp - i32(0x20)),
          ((cp >= i32(0xF8)) && (cp <= i32(0xFE))) => (cp - i32(0x20)),
          ((cp >= i32(0x3B1)) && (cp <= i32(0x3C1))) => (cp - i32(0x20)),
          ((cp >= i32(0x3C3)) && (cp <= i32(0x3C9))) => (cp - i32(0x20)),
          (cp == i32(0x3C2)) => i32(0x3A3),
          (cp == i32(0x3D1)) => i32(0x398),
          (cp == i32(0x3F4)) => i32(0x398),
          (cp == i32(0x3D5)) => i32(0x3A6),
          (cp == i32(0x3D6)) => i32(0x3A0),
          (cp == i32(0x3F5)) => i32(0x395),
          (cp == i32(0x2126)) => i32(0x3A9),
          (cp == i32(0x212A)) => i32(0x4B),
          (cp == i32(0x212B)) => i32(0xC5),
          true => cp
        );
        if((upper < i32(0x80)), {
          _ := result.push(u8(upper));
        }, if((upper < i32(0x800)), {
          _ := result.push(u8((i32(0xC0) + (upper / i32(64)))));
          _ := result.push(u8((i32(0x80) + (upper % i32(64)))));
        }, if((upper < i32(0x10000)), {
          _ := result.push(u8((i32(0xE0) + (upper / i32(4096)))));
          _ := result.push(u8((i32(0x80) + ((upper / i32(64)) % i32(64)))));
          _ := result.push(u8((i32(0x80) + (upper % i32(64)))));
        }, {
          _ := result.push(u8((i32(0xF0) + (upper / i32(262144)))));
          _ := result.push(u8((i32(0x80) + ((upper / i32(4096)) % i32(64)))));
          _ := result.push(u8((i32(0x80) + ((upper / i32(64)) % i32(64)))));
          _ := result.push(u8((i32(0x80) + (upper % i32(64)))));
        })));
      }))))))))));
    });
  };
  // Trim trailing space
  if(((result._length > usize(0)) && (result.get_unchecked((result._length - usize(1))) == u8(0x20))), {
    result._length = (result._length - usize(1));
  });
  String.from_bytes(result)
});

// Resolve emphasis/strong/strikethrough pairs for delimiters in range [start_idx, end_idx).
// Shrinks text tokens and appends resolved pairs to state.resolved_pairs.
// After calling, the caller should truncate delimiters to start_idx.
_resolve_scoped_emphasis :: (fn(state: *(InlineState), start_idx: i32, end_idx: i32) -> unit)({
  (closer_idx : i32) = start_idx;

  while (closer_idx < end_idx), {
    (closer : Delimiter) = state.*.delimiters.get_unchecked(usize(closer_idx));
    (is_em_marker : bool) = ((i32(closer.marker) == i32(0x2A)) || (i32(closer.marker) == i32(0x5F)));
    (is_strike : bool) = (i32(closer.marker) == i32(0x7E));

    if((closer.close && (is_em_marker || is_strike)), {
      (keep_matching : bool) = (closer.length > i32(0));
      while keep_matching, {
        (opener_idx : i32) = (closer_idx - i32(1));
        (found : bool) = false;

        // Only search back to start_idx — don't cross link scope boundary
        while ((opener_idx >= start_idx) && !(found)), {
          (opener : Delimiter) = state.*.delimiters.get_unchecked(usize(opener_idx));
          if(((opener.marker == closer.marker) && (opener.open && (opener.length > i32(0)))), {
            (skip : bool) = false;
            if(is_em_marker, {
              if(((closer.open || opener.close) && (((opener.length + closer.length) % i32(3)) == i32(0))), {
                if((((opener.length % i32(3)) != i32(0)) || ((closer.length % i32(3)) != i32(0))), {
                  skip = true;
                });
              });
            });
            if(!(skip), {
              found = true;
            }, {
              opener_idx = (opener_idx - i32(1));
            });
          }, {
            opener_idx = (opener_idx - i32(1));
          });
        };

        if(found, {
          (opener : Delimiter) = state.*.delimiters.get_unchecked(usize(opener_idx));
          (consume : i32) = cond(
            is_strike => i32(2),
            ((opener.length >= i32(2)) && (closer.length >= i32(2))) => i32(2),
            true => i32(1)
          );
          (pt : i32) = cond(
            is_strike => i32(3),
            (consume == i32(2)) => i32(2),
            true => i32(1)
          );

          _ := state.*.resolved_pairs.push(EmphasisPair(
            opener_tok: opener.token_idx,
            closer_tok: closer.token_idx,
            consume: consume,
            pair_type: pt
          ));

          // Shrink opener text token from end
          (otok : InlineToken) = state.*.tokens.get_unchecked(usize(opener.token_idx));
          state.*.tokens.set(usize(opener.token_idx), InlineToken(
            type_name: otok.type_name,
            start: otok.start, end: (otok.end - consume),
            nesting: otok.nesting, level: otok.level,
            info_start: otok.info_start, info_end: otok.info_end,
            title_start: otok.title_start, title_end: otok.title_end,
            markup_char: otok.markup_char, markup_len: otok.markup_len,
            content: otok.content, href: otok.href, title: otok.title,
            block: otok.block, hidden: otok.hidden
          ));

          // Shrink closer text token from start
          (ctok : InlineToken) = state.*.tokens.get_unchecked(usize(closer.token_idx));
          state.*.tokens.set(usize(closer.token_idx), InlineToken(
            type_name: ctok.type_name,
            start: (ctok.start + consume), end: ctok.end,
            nesting: ctok.nesting, level: ctok.level,
            info_start: ctok.info_start, info_end: ctok.info_end,
            title_start: ctok.title_start, title_end: ctok.title_end,
            markup_char: ctok.markup_char, markup_len: ctok.markup_len,
            content: ctok.content, href: ctok.href, title: ctok.title,
            block: ctok.block, hidden: ctok.hidden
          ));

          // Update delimiter lengths
          state.*.delimiters.set(usize(opener_idx), Delimiter(
            marker: opener.marker,
            length: (opener.length - consume),
            token_idx: opener.token_idx,
            end: closer_idx,
            jump: i32(0),
            open: opener.open,
            close: opener.close
          ));
          (new_closer_len : i32) = (closer.length - consume);
          state.*.delimiters.set(usize(closer_idx), Delimiter(
            marker: closer.marker,
            length: new_closer_len,
            token_idx: closer.token_idx,
            end: opener_idx,
            jump: i32(0),
            open: closer.open,
            close: closer.close
          ));
          closer = state.*.delimiters.get_unchecked(usize(closer_idx));

          // Clear delimiters between opener and closer
          (mid : i32) = (opener_idx + i32(1));
          while (mid < closer_idx), {
            (d : Delimiter) = state.*.delimiters.get_unchecked(usize(mid));
            state.*.delimiters.set(usize(mid), Delimiter(
              marker: d.marker, length: i32(0), token_idx: d.token_idx,
              end: i32(-1), jump: i32(0), open: false, close: false
            ));
            mid = (mid + i32(1));
          };

          keep_matching = (closer.length > i32(0));
        }, {
          keep_matching = false;
        });
      };
    });

    closer_idx = (closer_idx + i32(1));
  };
});

// Phase 1: Push a bracket marker when [ or ![ is encountered.
// The inline parser continues parsing content after the bracket,
// so emphasis/code/etc inside will be properly tokenized.
inline_link_open :: (fn(state: *(InlineState)) -> bool)({
  (pos : i32) = state.*.pos;
  (max : i32) = state.*.pos_max;

  (ch : i32) = i32((state.*.src_ptr &+ usize(pos)).*);

  (is_image : bool) = false;
  (bracket_pos : i32) = pos;
  if((ch == i32(0x21)), {
    if(((pos + i32(1)) < max), {
      if((i32((state.*.src_ptr &+ usize((pos + i32(1)))).*) == i32(0x5B)), {
        is_image = true;
        bracket_pos = (pos + i32(2));
      }, {
        return false;
      });
    }, {
      return false;
    });
  }, {
    if((ch == i32(0x5B)), {
      // For non-image links, check if link nesting is too deep
      if(((state.*.link_level > i32(0)) && !(is_image)), {
        // Links cannot nest inside links (but images can nest inside links)
      });
      bracket_pos = (pos + i32(1));
    }, {
      return false;
    });
  });

  // Flush pending text
  state.*.push_pending();

  // Record token index for the [ marker (we emit a placeholder text token)
  (tok_idx : i32) = i32(state.*.tokens.len());
  if(is_image, {
    _ := state.*.tokens.push(InlineToken.text(pos, (pos + i32(2)), state.*.level));
  }, {
    _ := state.*.tokens.push(InlineToken.text(pos, (pos + i32(1)), state.*.level));
  });

  // Push link marker
  _ := state.*.link_markers.push(LinkMarker(
    pos: bracket_pos,
    token_idx: tok_idx,
    is_image: is_image,
    active: true,
    delimiters_count: i32(state.*.delimiters.len())
  ));

  state.*.pos = bracket_pos;
  state.*.pending_start = state.*.pos;
  state.*.pending_end = state.*.pos;
  true
});

// Phase 2: When ] is encountered, try to resolve as link/image.
// Scans backward in link_markers for a matching [.
inline_link_close :: (fn(state: *(InlineState)) -> bool)({
  (pos : i32) = state.*.pos;
  (max : i32) = state.*.pos_max;

  if((i32((state.*.src_ptr &+ usize(pos)).*) != i32(0x5D)), { return false; });

  // Find last active link marker
  (marker_idx : i32) = (i32(state.*.link_markers.len()) - i32(1));
  (found_marker : bool) = false;
  while ((marker_idx >= i32(0)) && !(found_marker)), {
    if(state.*.link_markers.get_unchecked(usize(marker_idx)).active, {
      found_marker = true;
    }, {
      marker_idx = (marker_idx - i32(1));
    });
  };

  if(!(found_marker), {
    // No active marker — just emit ] as text
    return false;
  });

  (marker : LinkMarker) = state.*.link_markers.get_unchecked(usize(marker_idx));
  (is_image : bool) = marker.is_image;

  (after_close : i32) = (pos + i32(1));

  // Try to parse what follows ]
  (href_start : i32) = i32(0);
  (href_end : i32) = i32(0);
  (title_start : i32) = i32(0);
  (title_end : i32) = i32(0);
  (link_end : i32) = i32(-1);

  // Reference link state
  (ref_href : String) = ``;
  (ref_title : String) = ``;
  (is_ref : bool) = false;

  if(((after_close < max) && (i32((state.*.src_ptr &+ usize(after_close)).*) == i32(0x28))), {
    // Inline link: [text](url "title")
    (p : i32) = (after_close + i32(1));

    // Skip whitespace (spaces, tabs, newlines)
    while ((p < max) && (is_space(i32((state.*.src_ptr &+ usize(p)).*)) || (i32((state.*.src_ptr &+ usize(p)).*) == i32(0x0A)))), {
      p = (p + i32(1));
    };

    // Parse destination
    (dest_start : i32) = p;
    (dest_result : i32) = _parse_link_dest(state.*.src_ptr, p, max);
    if((dest_result >= i32(0)), {
      if((i32((state.*.src_ptr &+ usize(dest_start)).*) == i32(0x3C)), {
        href_start = (dest_start + i32(1));
        href_end = (dest_result - i32(1));
      }, {
        href_start = dest_start;
        href_end = dest_result;
      });
      p = dest_result;

      // Skip whitespace (spaces, tabs, newlines)
      (saved_p : i32) = p;
      while ((p < max) && (is_space(i32((state.*.src_ptr &+ usize(p)).*)) || (i32((state.*.src_ptr &+ usize(p)).*) == i32(0x0A)))), {
        p = (p + i32(1));
      };

      // Try parse title
      if((p != saved_p), {
        (title_result : i32) = _parse_link_title(state.*.src_ptr, p, max);
        if((title_result >= i32(0)), {
          title_start = (p + i32(1));
          title_end = (title_result - i32(1));
          p = title_result;
        });
      });

      // Skip trailing whitespace
      while ((p < max) && (is_space(i32((state.*.src_ptr &+ usize(p)).*)) || (i32((state.*.src_ptr &+ usize(p)).*) == i32(0x0A)))), {
        p = (p + i32(1));
      };

      if(((p < max) && (i32((state.*.src_ptr &+ usize(p)).*) == i32(0x29))), {
        link_end = (p + i32(1));
      });
    });
  });

  if((link_end < i32(0)), {
    // Try reference: [text][label], [text][], [text]
    (ref_start : i32) = i32(-1);
    (ref_end : i32) = i32(-1);
    if(((after_close < max) && (i32((state.*.src_ptr &+ usize(after_close)).*) == i32(0x5B))), {
      (label_start : i32) = (after_close + i32(1));
      (label_end_pos : i32) = _find_close_bracket(state.*.src_ptr, label_start, max);
      if((label_end_pos >= i32(0)), {
        if((label_end_pos > label_start), {
          ref_start = label_start;
          ref_end = label_end_pos;
          link_end = (label_end_pos + i32(1));
        }, {
          ref_start = marker.pos;
          ref_end = pos;
          link_end = (label_end_pos + i32(1));
        });
      });
    }, {
      // Shortcut: [text]
      ref_start = marker.pos;
      ref_end = pos;
      link_end = after_close;
    });

    if((ref_start >= i32(0)), {
      (label : String) = _normalize_label(state.*.src_ptr, ref_start, ref_end);
      if((label.len() > usize(0)), {
        (maybe_ref : Option(Reference)) = state.*.env.*.references.get(label);
        match(maybe_ref,
          .Some(r) => {
            ref_href = r.href;
            ref_title = r.title;
            is_ref = true;
          },
          .None => ()
        );
      });
    });

    if(!(is_ref), {
      // Could not resolve — deactivate this marker
      state.*.link_markers.get_ptr(usize(marker_idx)).*.active = false;
      return false;
    });
  });

  if(!(is_ref), {
    if(!(validate_link_url(state.*.src_ptr, href_start, href_end)), {
      state.*.link_markers.get_ptr(usize(marker_idx)).*.active = false;
      return false;
    });
  });

  // === Link matched! ===

  // Flush pending text before ]
  state.*.push_pending();

  // Process emphasis delimiters that were inside the link text.
  // Resolve pairs scoped to [delim_start, current_len) so emphasis
  // can't cross link boundaries, then truncate delimiters.
  (delim_start : i32) = marker.delimiters_count;
  (delim_end : i32) = i32(state.*.delimiters.len());
  if((delim_end > delim_start), {
    _resolve_scoped_emphasis(state, delim_start, delim_end);
    state.*.delimiters._length = usize(delim_start);
  });

  (open_token_idx : i32) = marker.token_idx;

  // Replace the [ placeholder token with LinkOpen/ImageOpen
  (open_type : InlineType) = cond(
    is_image => .ImageOpen,
    true => .LinkOpen
  );

  if(is_ref, {
    (tok_ptr : *(InlineToken)) = state.*.tokens.get_ptr(usize(open_token_idx));
    tok_ptr.* = InlineToken(
      type_name: open_type,
      start: i32(0), end: i32(0),
      nesting: i32(1), level: state.*.level,
      info_start: i32(0), info_end: i32(0),
      title_start: i32(0), title_end: i32(0),
      markup_char: u8(0), markup_len: u8(0),
      content: ``, href: ref_href, title: ref_title,
      block: false, hidden: false
    );
  }, {
    (tok_ptr : *(InlineToken)) = state.*.tokens.get_ptr(usize(open_token_idx));
    tok_ptr.* = InlineToken(
      type_name: open_type,
      start: href_start, end: href_end,
      nesting: i32(1), level: state.*.level,
      info_start: i32(0), info_end: i32(0),
      title_start: title_start, title_end: title_end,
      markup_char: u8(0), markup_len: u8(0),
      content: ``, href: ``, title: ``,
      block: false, hidden: false
    );
  });

  // Emit close token
  (close_type : InlineType) = cond(
    is_image => .ImageClose,
    true => .LinkClose
  );
  _ := state.*.tokens.push(InlineToken.simple(close_type, i32(-1), state.*.level));

  // For non-image links, deactivate all earlier link markers (links can't nest)
  if(!(is_image), {
    (i : i32) = i32(0);
    while (i < marker_idx), {
      if(!(state.*.link_markers.get_unchecked(usize(i)).is_image), {
        state.*.link_markers.get_ptr(usize(i)).*.active = false;
      });
      i = (i + i32(1));
    };
  });

  // Remove this marker and all after it
  // (Simply truncate the markers list)
  state.*.link_markers._length = usize(marker_idx);

  state.*.link_level = cond(
    is_image => state.*.link_level,
    true => (state.*.link_level + i32(1))
  );

  state.*.pos = link_end;
  state.*.pending_start = state.*.pos;
  state.*.pending_end = state.*.pos;
  true
});

export inline_link_open, inline_link_close, validate_link_url;
