// markdown_yo — HTML renderer
//
// SAX-style: receives direct calls from block and inline parsers.
// Writes directly to an ArrayList(u8) output buffer — no intermediate Strings.

open import "std/string";
{ ArrayList } :: import "std/collections/array_list";
{ memmove } :: import "std/libc/string";
{ Options, TableAlign } :: import "./types.yo";
{ escape_html_buf, append_raw_buf, append_lit } :: import "./common/utils.yo";
{ decode_named_entity } :: import "./common/entities.yo";

// In-place move: copy `count` bytes from s+src_off to s+dst_off (skip when equal)
_memmove_inline :: (fn(s: *(u8), dst_off: usize, src_off: usize, count: usize) -> unit)(
  if((dst_off != src_off), {
    _ := memmove(*(void)((s &+ dst_off)), *(void)((s &+ src_off)), count);
  })
);

// Helper: write i32 as decimal ASCII digits to buffer
_write_i32 :: (fn(buf: *(ArrayList(u8)), n: i32) -> unit)({
  if((n < i32(0)), {
    _ := buf.*.push(u8(0x2D)); // '-'
    recur(buf, (i32(0) - n));
    return ();
  });
  if((n >= i32(10)), {
    recur(buf, (n / i32(10)));
  });
  _ := buf.*.push(u8((i32(0x30) + (n % i32(10)))));
});

// Encode a Unicode code point as UTF-8 and HTML-escape it, writing to buf
_emit_code_point :: (fn(buf: *(ArrayList(u8)), raw_code: i32) -> unit)({
  // Validate codepoint: replace invalid with U+FFFD
  // Invalid: 0, surrogates (0xD800-0xDFFF), > 0x10FFFF, certain control chars
  (code : i32) = cond(
    (raw_code == i32(0)) => i32(0xFFFD),
    ((raw_code >= i32(0xD800)) && (raw_code <= i32(0xDFFF))) => i32(0xFFFD),
    (raw_code > i32(0x10FFFF)) => i32(0xFFFD),
    // C0 controls except tab, newline, CR  
    ((raw_code >= i32(0x01)) && (raw_code <= i32(0x08))) => i32(0xFFFD),
    (raw_code == i32(0x0B)) => i32(0xFFFD),
    ((raw_code >= i32(0x0E)) && (raw_code <= i32(0x1F))) => i32(0xFFFD),
    ((raw_code >= i32(0x7F)) && (raw_code <= i32(0x9F))) => i32(0xFFFD),
    ((raw_code >= i32(0xFDD0)) && (raw_code <= i32(0xFDEF))) => i32(0xFFFD),
    true => raw_code
  );
  // Also check noncharacters: xFFFE, xFFFF, x1FFFE, x1FFFF etc.
  (final_code : i32) = cond(
    (((code & i32(0xFFFF)) == i32(0xFFFE)) || ((code & i32(0xFFFF)) == i32(0xFFFF))) => i32(0xFFFD),
    true => code
  );
  cond(
    (final_code == i32(0x26)) => append_lit(buf, "&amp;"),
    (final_code == i32(0x3C)) => append_lit(buf, "&lt;"),
    (final_code == i32(0x3E)) => append_lit(buf, "&gt;"),
    (final_code == i32(0x22)) => append_lit(buf, "&quot;"),
    true => {
      cond(
        (final_code < i32(0x80)) => {
          _ := buf.*.push(u8(final_code));
        },
        (final_code < i32(0x800)) => {
          _ := buf.*.push(u8((i32(0xC0) | (final_code >> i32(6)))));
          _ := buf.*.push(u8((i32(0x80) | (final_code & i32(0x3F)))));
        },
        (final_code < i32(0x10000)) => {
          _ := buf.*.push(u8((i32(0xE0) | (final_code >> i32(12)))));
          _ := buf.*.push(u8((i32(0x80) | ((final_code >> i32(6)) & i32(0x3F)))));
          _ := buf.*.push(u8((i32(0x80) | (final_code & i32(0x3F)))));
        },
        true => {
          _ := buf.*.push(u8((i32(0xF0) | (final_code >> i32(18)))));
          _ := buf.*.push(u8((i32(0x80) | ((final_code >> i32(12)) & i32(0x3F)))));
          _ := buf.*.push(u8((i32(0x80) | ((final_code >> i32(6)) & i32(0x3F)))));
          _ := buf.*.push(u8((i32(0x80) | (final_code & i32(0x3F)))));
        }
      );
    }
  );
});

// ============================================================================
// Typographer helpers — simple text replacements
// ============================================================================

// Lower-case a byte (ASCII only)
_typo_lower :: (fn(b: u8) -> u8)(
  cond(
    ((b >= u8(0x41)) && (b <= u8(0x5A))) => (b + u8(0x20)),
    true => b
  )
);

// Emit typographer-processed text to buf, HTML-escaping as we go.
// Replaces (c)→©, (r)→®, (tm)→™, +-→±, ...→…, dup punctuation, dashes.
_typographer_text :: (fn(buf: *(ArrayList(u8)), src: *(u8), start: i32, end: i32) -> unit)({
  (i : i32) = start;
  while (i < end), {
    (b : u8) = (src &+ usize(i)).*;
    (ch : i32) = i32(b);
    (remaining : i32) = (end - i);

    cond(
      // --- Scoped abbreviations: (c), (r), (tm) ---
      ((ch == i32(0x28)) && (remaining >= i32(3))) => {
        (c1 : u8) = _typo_lower((src &+ usize((i + i32(1)))).*);
        (c2 : u8) = (src &+ usize((i + i32(2)))).*;

        if(((c2 == u8(0x29)) && (c1 == u8(0x63))), {
          // (c) → © (UTF-8: 0xC2 0xA9)
          _ := buf.*.push(u8(0xC2));
          _ := buf.*.push(u8(0xA9));
          i = (i + i32(3));
        }, if(((c2 == u8(0x29)) && (c1 == u8(0x72))), {
          // (r) → ® (UTF-8: 0xC2 0xAE)
          _ := buf.*.push(u8(0xC2));
          _ := buf.*.push(u8(0xAE));
          i = (i + i32(3));
        }, if(((remaining >= i32(4)) && (c1 == u8(0x74))), {
          (c2b : u8) = _typo_lower((src &+ usize((i + i32(2)))).*);
          (c3 : u8) = (src &+ usize((i + i32(3)))).*;
          if(((c2b == u8(0x6D)) && (c3 == u8(0x29))), {
            // (tm) → ™ (UTF-8: 0xE2 0x84 0xA2)
            _ := buf.*.push(u8(0xE2));
            _ := buf.*.push(u8(0x84));
            _ := buf.*.push(u8(0xA2));
            i = (i + i32(4));
          }, {
            // Not a match — emit '(' HTML-escaped
            escape_html_buf(buf, src, i, (i + i32(1)));
            i = (i + i32(1));
          });
        }, {
          escape_html_buf(buf, src, i, (i + i32(1)));
          i = (i + i32(1));
        })));
      },

      // --- Plus-minus: +- → ± ---
      ((ch == i32(0x2B)) && ((remaining >= i32(2)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x2D)))) => {
        // ± (UTF-8: 0xC2 0xB1)
        _ := buf.*.push(u8(0xC2));
        _ := buf.*.push(u8(0xB1));
        i = (i + i32(2));
      },

      // --- Dots: .. or more → … with special ?/! rules ---
      ((ch == i32(0x2E)) && ((remaining >= i32(2)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x2E)))) => {
        // Count consecutive dots
        (dot_end : i32) = (i + i32(2));
        while (((dot_end < end) && (i32((src &+ usize(dot_end)).*) == i32(0x2E)))), {
          dot_end = (dot_end + i32(1));
        };
        // Check if preceded by ? or ! → revert to ?.. or !..
        (prev_ch : i32) = cond(
          (i > start) => i32((src &+ usize((i - i32(1)))).*),
          true => {
            // Check last byte in buf
            if((buf.*.len() > usize(0)), {
              i32(buf.*((buf.*.len() - usize(1))))
            }, { i32(0) })
          }
        );
        if(((prev_ch == i32(0x3F)) || (prev_ch == i32(0x21))), {
          // ?.. or !.. — two literal dots
          _ := buf.*.push(u8(0x2E));
          _ := buf.*.push(u8(0x2E));
        }, {
          // … (UTF-8: 0xE2 0x80 0xA6)
          _ := buf.*.push(u8(0xE2));
          _ := buf.*.push(u8(0x80));
          _ := buf.*.push(u8(0xA6));
        });
        i = dot_end;
      },

      // --- Collapse duplicate punctuation: ?, !, , ---
      ((ch == i32(0x3F)) && ((remaining >= i32(4)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x3F)))) => {
        // Count consecutive ?
        (qend : i32) = (i + i32(2));
        while (((qend < end) && (i32((src &+ usize(qend)).*) == i32(0x3F)))), {
          qend = (qend + i32(1));
        };
        if(((qend - i) >= i32(4)), {
          _ := buf.*.push(u8(0x3F));
          _ := buf.*.push(u8(0x3F));
          _ := buf.*.push(u8(0x3F));
          i = qend;
        }, {
          escape_html_buf(buf, src, i, (i + i32(1)));
          i = (i + i32(1));
        });
      },

      ((ch == i32(0x21)) && ((remaining >= i32(4)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x21)))) => {
        // Count consecutive !
        (eend : i32) = (i + i32(2));
        while (((eend < end) && (i32((src &+ usize(eend)).*) == i32(0x21)))), {
          eend = (eend + i32(1));
        };
        if(((eend - i) >= i32(4)), {
          _ := buf.*.push(u8(0x21));
          _ := buf.*.push(u8(0x21));
          _ := buf.*.push(u8(0x21));
          i = eend;
        }, {
          escape_html_buf(buf, src, i, (i + i32(1)));
          i = (i + i32(1));
        });
      },

      ((ch == i32(0x2C)) && ((remaining >= i32(2)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x2C)))) => {
        // Count consecutive commas, collapse to single
        (cend : i32) = (i + i32(2));
        while (((cend < end) && (i32((src &+ usize(cend)).*) == i32(0x2C)))), {
          cend = (cend + i32(1));
        };
        _ := buf.*.push(u8(0x2C));
        i = cend;
      },

      // --- Em-dash: --- → — (not preceded/followed by -) ---
      ((ch == i32(0x2D)) && ((remaining >= i32(3)) && ((i32((src &+ usize((i + i32(1)))).*)  == i32(0x2D)) && (i32((src &+ usize((i + i32(2)))).*)  == i32(0x2D))))) => {
        // Check not preceded by '-'
        (preceded_by_dash : bool) = ((i > start) && (i32((src &+ usize((i - i32(1)))).*)  == i32(0x2D)));
        // Check not followed by '-'
        (followed_by_dash : bool) = (((i + i32(3)) < end) && (i32((src &+ usize((i + i32(3)))).*)  == i32(0x2D)));
        if((!(preceded_by_dash) && !(followed_by_dash)), {
          // — em dash (UTF-8: 0xE2 0x80 0x94)
          _ := buf.*.push(u8(0xE2));
          _ := buf.*.push(u8(0x80));
          _ := buf.*.push(u8(0x94));
          i = (i + i32(3));
        }, {
          escape_html_buf(buf, src, i, (i + i32(1)));
          i = (i + i32(1));
        });
      },

      // --- En-dash: -- → – (two regex passes from markdown-it) ---
      // Pass 1: (^|\s)--(?=\s|$)  — whitespace-surrounded
      // Pass 2: (^|[^-\s])--(?=[^-\s]|$) — word-surrounded
      // ^ matches both: it counts as whitespace AND as non-dash-non-space
      ((ch == i32(0x2D)) && ((remaining >= i32(2)) && (i32((src &+ usize((i + i32(1)))).*)  == i32(0x2D)))) => {
        (preceded_by_dash : bool) = ((i > start) && (i32((src &+ usize((i - i32(1)))).*)  == i32(0x2D)));
        (followed_by_dash : bool) = (((i + i32(2)) < end) && (i32((src &+ usize((i + i32(2)))).*)  == i32(0x2D)));
        if((!(preceded_by_dash) && !(followed_by_dash)), {
          // Pass 1: (^|\s)--(?=\s|$)
          (prev_ws_or_start : bool) = cond(
            (i == start) => true,
            true => {
              (pb : i32) = i32((src &+ usize((i - i32(1)))).*);
              ((pb == i32(0x20)) || ((pb == i32(0x09)) || ((pb == i32(0x0A)) || (pb == i32(0x0D)))))
            }
          );
          (next_ws_or_end : bool) = cond(
            ((i + i32(2)) >= end) => true,
            true => {
              (nb : i32) = i32((src &+ usize((i + i32(2)))).*);
              ((nb == i32(0x20)) || ((nb == i32(0x09)) || ((nb == i32(0x0A)) || (nb == i32(0x0D)))))
            }
          );
          // Pass 2: (^|[^-\s])--(?=[^-\s]|$)
          (prev_nds_or_start : bool) = cond(
            (i == start) => true,
            true => {
              (pb : i32) = i32((src &+ usize((i - i32(1)))).*);
              ((pb != i32(0x2D)) && ((pb != i32(0x20)) && ((pb != i32(0x09)) && ((pb != i32(0x0A)) && (pb != i32(0x0D))))))
            }
          );
          (next_nds_or_end : bool) = cond(
            ((i + i32(2)) >= end) => true,
            true => {
              (nb : i32) = i32((src &+ usize((i + i32(2)))).*);
              ((nb != i32(0x2D)) && ((nb != i32(0x20)) && ((nb != i32(0x09)) && ((nb != i32(0x0A)) && (nb != i32(0x0D))))))
            }
          );
          if(((prev_ws_or_start && next_ws_or_end) || (prev_nds_or_start && next_nds_or_end)), {
            // – en dash (UTF-8: 0xE2 0x80 0x93)
            _ := buf.*.push(u8(0xE2));
            _ := buf.*.push(u8(0x80));
            _ := buf.*.push(u8(0x93));
            i = (i + i32(2));
          }, {
            escape_html_buf(buf, src, i, (i + i32(1)));
            i = (i + i32(1));
          });
        }, {
          escape_html_buf(buf, src, i, (i + i32(1)));
          i = (i + i32(1));
        });
      },

      // --- Default: HTML-escape and emit ---
      true => {
        escape_html_buf(buf, src, i, (i + i32(1)));
        i = (i + i32(1));
      }
    );
  };
});

HtmlRenderer :: struct(
  buf : ArrayList(u8),    // output buffer
  img_nest : i32,         // depth inside <img> alt text (suppress HTML tags)
  img_title : String,     // saved image title (from open to close)
  options : *(Options),
  src_ptr : *(u8),        // pointer to source bytes for zero-copy slicing
  src_len : i32,
  list_nesting : i32,     // list nesting depth (for tight paragraph removal)
  tight_mode : bool,      // when true, paragraph open/close emit nothing
  bq_buf_pos : i32,       // buffer position at blockquote open (for empty detection)
  _entity_buf : ArrayList(u8)  // reusable buffer for entity decoding
);

impl(HtmlRenderer,
  new : (fn(options: *(Options), src_ptr: *(u8), src_len: i32) -> Self)({
    // Pre-allocate ~2× source size (HTML expansion from tags)
    (cap : usize) = (usize(src_len) * usize(2));
    Self(
      buf: ArrayList(u8).with_capacity(cap),
      img_nest: i32(0),
      img_title: ``,
      options: options,
      src_ptr: src_ptr,
      src_len: src_len,
      list_nesting: i32(0),
      tight_mode: false,
      bq_buf_pos: i32(-1),
      _entity_buf: ArrayList(u8).with_capacity(usize(16))
    )
  }),

  // Get the rendered output as a String (transfers ownership of buffer)
  finish : (fn(self: Self) -> String)(
    String.from_bytes(self.buf)
  ),

  // -------------------------------------------------------------------
  // Low-level append helpers
  // -------------------------------------------------------------------

  // Append literal string
  lit : (fn(self: *(Self), s: str) -> unit)(
    append_lit((&self.*.buf), s)
  ),

  // Append HTML-escaped source bytes [start, end)
  escaped : (fn(self: *(Self), start: i32, end: i32) -> unit)(
    escape_html_buf((&self.*.buf), self.*.src_ptr, start, end)
  ),

  // Append HTML-escaped source bytes with backslash unescape + entity decode
  escaped_unesc : (fn(self: *(Self), start: i32, end: i32) -> unit)({
    (i : i32) = start;
    while (i < end), {
      (b : u8) = (self.*.src_ptr &+ usize(i)).*;
      cond(
        // Backslash escape
        ((b == u8(0x5C)) && ((i + i32(1)) < end)) => {
          (next : u8) = (self.*.src_ptr &+ usize((i + i32(1)))).*;
          // Check if next is ASCII punctuation
          if((((next >= u8(0x21)) && (next <= u8(0x2F)))
           || ((next >= u8(0x3A)) && (next <= u8(0x40)))
           || ((next >= u8(0x5B)) && (next <= u8(0x60)))
           || ((next >= u8(0x7B)) && (next <= u8(0x7E)))), {
            // Emit the unescaped char (HTML-escaped)
            _emit_code_point((&self.*.buf), i32(next));
            i = (i + i32(2));
          }, {
            escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
            i = (i + i32(1));
          });
        },
        // Entity: &...;
        ((b == u8(0x26)) && ((i + i32(2)) < end)) => {
          (ch1 : i32) = i32((self.*.src_ptr &+ usize((i + i32(1)))).*);
          if((ch1 == i32(0x23)), {
            // Numeric entity &#...;
            (p : i32) = (i + i32(2));
            (ch2 : i32) = i32((self.*.src_ptr &+ usize(p)).*);
            if(((ch2 == i32(0x78)) || (ch2 == i32(0x58))), {
              // Hex &#xHHHH;
              (hp : i32) = (p + i32(1));
              while ((hp < end) && ((((i32((self.*.src_ptr &+ usize(hp)).*) >= i32(0x30)) && (i32((self.*.src_ptr &+ usize(hp)).*) <= i32(0x39))) || ((i32((self.*.src_ptr &+ usize(hp)).*) >= i32(0x41)) && (i32((self.*.src_ptr &+ usize(hp)).*) <= i32(0x46)))) || ((i32((self.*.src_ptr &+ usize(hp)).*) >= i32(0x61)) && (i32((self.*.src_ptr &+ usize(hp)).*) <= i32(0x66))))), {
                hp = (hp + i32(1));
              };
              if(((hp < end) && ((hp > (p + i32(1))) && (i32((self.*.src_ptr &+ usize(hp)).*) == i32(0x3B)))), {
                (code : i32) = i32(0);
                (dp : i32) = (p + i32(1));
                while (dp < hp), {
                  (d : i32) = i32((self.*.src_ptr &+ usize(dp)).*);
                  code = (code * i32(16));
                  cond(
                    ((d >= i32(0x30)) && (d <= i32(0x39))) => { code = (code + (d - i32(0x30))); },
                    ((d >= i32(0x41)) && (d <= i32(0x46))) => { code = (code + ((d - i32(0x41)) + i32(10))); },
                    ((d >= i32(0x61)) && (d <= i32(0x66))) => { code = (code + ((d - i32(0x61)) + i32(10))); },
                    true => ()
                  );
                  dp = (dp + i32(1));
                };
                _emit_code_point((&self.*.buf), code);
                i = (hp + i32(1));
              }, {
                escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
                i = (i + i32(1));
              });
            }, {
              // Decimal &#DDD;
              (dp : i32) = p;
              while ((dp < end) && ((i32((self.*.src_ptr &+ usize(dp)).*) >= i32(0x30)) && (i32((self.*.src_ptr &+ usize(dp)).*) <= i32(0x39)))), {
                dp = (dp + i32(1));
              };
              if(((dp < end) && ((dp > p) && (i32((self.*.src_ptr &+ usize(dp)).*) == i32(0x3B)))), {
                (code : i32) = i32(0);
                (np : i32) = p;
                while (np < dp), {
                  code = ((code * i32(10)) + (i32((self.*.src_ptr &+ usize(np)).*) - i32(0x30)));
                  np = (np + i32(1));
                };
                _emit_code_point((&self.*.buf), code);
                i = (dp + i32(1));
              }, {
                escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
                i = (i + i32(1));
              });
            });
          }, {
            // Named entity &name;
            if(((ch1 >= i32(0x41)) && (ch1 <= i32(0x7A))), {
              (np : i32) = (i + i32(2));
              (nlen : i32) = i32(1);
              while ((np < end) && ((nlen < i32(31)) && ((((i32((self.*.src_ptr &+ usize(np)).*) >= i32(0x41)) && (i32((self.*.src_ptr &+ usize(np)).*) <= i32(0x5A))) || ((i32((self.*.src_ptr &+ usize(np)).*) >= i32(0x61)) && (i32((self.*.src_ptr &+ usize(np)).*) <= i32(0x7A)))) || ((i32((self.*.src_ptr &+ usize(np)).*) >= i32(0x30)) && (i32((self.*.src_ptr &+ usize(np)).*) <= i32(0x39)))))), {
                nlen = (nlen + i32(1));
                np = (np + i32(1));
              };
              if(((np < end) && (i32((self.*.src_ptr &+ usize(np)).*) == i32(0x3B))), {
                (name_ptr : *(u8)) = (self.*.src_ptr &+ usize((i + i32(1))));
                self.*._entity_buf.clear();
                if(decode_named_entity(name_ptr, nlen, (&self.*._entity_buf)), {
                  match(self.*._entity_buf.ptr(),
                    .Some(p) => escape_html_buf((&self.*.buf), p, i32(0), i32(self.*._entity_buf.len())),
                    .None => ()
                  );
                  i = (np + i32(1));
                }, {
                  escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
                  i = (i + i32(1));
                });
              }, {
                escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
                i = (i + i32(1));
              });
            }, {
              escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
              i = (i + i32(1));
            });
          });
        },
        true => {
          escape_html_buf((&self.*.buf), self.*.src_ptr, i, (i + i32(1)));
          i = (i + i32(1));
        }
      );
    };
  }),

  // Append raw source bytes [start, end) (no escaping)
  raw : (fn(self: *(Self), start: i32, end: i32) -> unit)(
    append_raw_buf((&self.*.buf), self.*.src_ptr, start, end)
  ),

  // Append a single byte
  byte : (fn(self: *(Self), b: u8) -> unit)({
    _ := self.*.buf.push(b);
  }),

  // Append a String (for dynamic content like lang_prefix)
  push_string : (fn(self: *(Self), s: String) -> unit)({
    (bytes : ArrayList(u8)) = s.as_bytes();
    match(bytes.ptr(),
      .Some(p) => self.*.buf.extend_from_ptr(p, bytes.len()),
      .None => ()
