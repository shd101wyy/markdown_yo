  text_string : (fn(self: *(Self), s: String) -> unit)(
    self.*.escaped_string(s)
  ),

  code_inline : (fn(self: *(Self), start: i32, end: i32) -> unit)({
    if((self.*.img_nest > i32(0)), { return (); });
    self.*.lit("<code>");
    // Line endings are treated as spaces in code spans (CommonMark spec)
    (i : i32) = start;
    (run_start : i32) = start;
    while (i < end), {
      (ch : u8) = (self.*.src_ptr &+ usize(i)).*;
      if((ch == u8(0x0A)), {
        // Flush preceding run with HTML escaping
        if((i > run_start), {
          escape_html_buf((&self.*.buf), self.*.src_ptr, run_start, i);
        });
        // Emit space instead of newline
        self.*.lit(" ");
        run_start = (i + i32(1));
      });
      i = (i + i32(1));
    };
    // Flush remaining
    if((end > run_start), {
      escape_html_buf((&self.*.buf), self.*.src_ptr, run_start, end);
    });
    self.*.lit("</code>");
  }),

  open_em : (fn(self: *(Self)) -> unit)(
    if((self.*.img_nest == i32(0)), {
      self.*.lit("<em>");
    })
  ),

  close_em : (fn(self: *(Self)) -> unit)(
    if((self.*.img_nest == i32(0)), {
      self.*.lit("</em>");
