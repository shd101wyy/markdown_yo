      (level == i32(1)) => self.*.lit("<h1>"),
      (level == i32(2)) => self.*.lit("<h2>"),
      (level == i32(3)) => self.*.lit("<h3>"),
      (level == i32(4)) => self.*.lit("<h4>"),
      (level == i32(5)) => self.*.lit("<h5>"),
      true => self.*.lit("<h6>")
