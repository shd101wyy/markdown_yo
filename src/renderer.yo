  close_unordered_list : (fn(self: *(Self)) -> unit)(
    self.*.lit("</ul>\n")
  ),

  open_ordered_list : (fn(self: *(Self), start: i32) -> unit)(
    if((start == i32(1)), {
      self.*.lit("<ol>\n");
    }, {
      self.*.lit("<ol start=\"");
      // Write start number as ASCII digits
      _write_i32((&self.*.buf), start);
      self.*.lit("\">\n");
