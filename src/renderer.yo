  escaped_raw : (fn(self: *(Self), buf: *(ArrayList(u8))) -> unit)(
    match(buf.*.ptr(),
      .Some(p) => escape_html_buf((&self.*.buf), p, i32(0), i32(buf.*.len())),
      .None => ()
    )
  ),

