  text : (fn(self: *(Self), start: i32, end: i32) -> unit)(
    if(self.*.options.*.typographer, {
      _typographer_text((&self.*.buf), self.*.src_ptr, start, end);
    }, {
      self.*.escaped(start, end);
    })
