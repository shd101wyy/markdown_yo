  close_strikethrough : (fn(self: *(Self)) -> unit)(
    if((self.*.img_nest == i32(0)), {
      self.*.lit("</s>");
    })
  ),

  // Link open: <a href="..." title="...">
  open_link : (fn(self: *(Self), href: String, title: String) -> unit)({
    if((self.*.img_nest > i32(0)), { return (); });
    self.*.lit("<a href=\"");
    self.*.escaped_string(href);
    if((title.len() > usize(0)), {
      self.*.lit("\" title=\"");
      self.*.escaped_string(title);
    });
    self.*.lit("\">");
  }),

  // Buffer-based: href from buf, title from String
  open_link_buf : (fn(self: *(Self), href_buf: *(ArrayList(u8)), title: String) -> unit)({
    if((self.*.img_nest > i32(0)), { return (); });
    self.*.lit("<a href=\"");
    self.*.escaped_raw(href_buf);
    if((title.len() > usize(0)), {
      self.*.lit("\" title=\"");
      self.*.escaped_string(title);
    });
    self.*.lit("\">");
  }),

  // Buffer-based: href from buf, title from raw bytes (zero-RC)
  open_link_buf_raw : (fn(self: *(Self), href_buf: *(ArrayList(u8)), title_ptr: *(u8), title_len: i32) -> unit)({
    if((self.*.img_nest > i32(0)), { return (); });
    self.*.lit("<a href=\"");
    self.*.escaped_raw(href_buf);
    if((title_len > i32(0)), {
      self.*.lit("\" title=\"");
      escape_html_buf((&self.*.buf), title_ptr, i32(0), title_len);
    });
    self.*.lit("\">");
  }),

  // Buffer-based: href from buf, title from buf
  open_link_raw : (fn(self: *(Self), href_buf: *(ArrayList(u8)), title_buf: *(ArrayList(u8))) -> unit)({
    if((self.*.img_nest > i32(0)), { return (); });
    self.*.lit("<a href=\"");
    self.*.escaped_raw(href_buf);
    if((title_buf.*.len() > usize(0)), {
      self.*.lit("\" title=\"");
      self.*.escaped_raw(title_buf);
    });
    self.*.lit("\">");
  }),

  close_link : (fn(self: *(Self)) -> unit)(
    if((self.*.img_nest == i32(0)), {
      self.*.lit("</a>");
    })
  ),

  // Image: <img src="..." alt="..." title="...">
  // After open_image, inline content becomes alt text.
  // close_image finishes the tag.
  open_image : (fn(self: *(Self), src: String, title: String) -> unit)({
    self.*.lit("<img src=\"");
    self.*.escaped_string(src);
    self.*.lit("\" alt=\"");
    self.*.img_title = title;
    self.*.img_nest = (self.*.img_nest + i32(1));
  }),

  // Buffer-based: src from buf, title from String
  open_image_buf : (fn(self: *(Self), src_buf: *(ArrayList(u8)), title: String) -> unit)({
    self.*.lit("<img src=\"");
    self.*.escaped_raw(src_buf);
    self.*.lit("\" alt=\"");
    self.*.img_title = title;
    self.*.img_nest = (self.*.img_nest + i32(1));
  }),

  // Buffer-based: src from buf, title from raw bytes (zero-RC)
  open_image_buf_raw : (fn(self: *(Self), src_buf: *(ArrayList(u8)), title_ptr: *(u8), title_len: i32) -> unit)({
    self.*.lit("<img src=\"");
    self.*.escaped_raw(src_buf);
    self.*.lit("\" alt=\"");
    // Store title as String for close_image (images are rare, so allocation is fine)
    if((title_len > i32(0)), {
      (title_bytes : ArrayList(u8)) = ArrayList(u8).with_capacity(usize(title_len));
      title_bytes.extend_from_ptr(title_ptr, usize(title_len));
      self.*.img_title = String.from_bytes(title_bytes);
    }, {
      self.*.img_title = ``;
    });
    self.*.img_nest = (self.*.img_nest + i32(1));
  }),

  // Buffer-based: src from buf, title from buf
  open_image_raw : (fn(self: *(Self), src_buf: *(ArrayList(u8)), title_buf: *(ArrayList(u8))) -> unit)({
    self.*.lit("<img src=\"");
    self.*.escaped_raw(src_buf);
    self.*.lit("\" alt=\"");
    // Must copy title into String for close_image (images are rare)
    (title_bytes : ArrayList(u8)) = ArrayList(u8).with_capacity(title_buf.*.len());
    match(title_buf.*.ptr(),
      .Some(p) => title_bytes.extend_from_ptr(p, title_buf.*.len()),
      .None => ()
    );
    self.*.img_title = String.from_bytes(title_bytes);
    self.*.img_nest = (self.*.img_nest + i32(1));
  }),

  close_image : (fn(self: *(Self)) -> unit)({
    (title : String) = self.*.img_title;
    if((title.len() > usize(0)), {
      self.*.lit("\" title=\"");
      self.*.escaped_string(title);
    });
    cond(
      self.*.options.*.xhtml_out => self.*.lit("\" />"),
      true => self.*.lit("\">")
    );
    self.*.img_nest = (self.*.img_nest - i32(1));
  }),

  softbreak : (fn(self: *(Self)) -> unit)(
    cond(
      (self.*.img_nest > i32(0)) => self.*.lit("\n"),
      self.*.options.*.breaks => cond(
        self.*.options.*.xhtml_out => self.*.lit("<br />\n"),
        true => self.*.lit("<br>\n")
      ),
      true => self.*.lit("\n")
    )
  ),

  hardbreak : (fn(self: *(Self)) -> unit)(
    cond(
      (self.*.img_nest > i32(0)) => self.*.lit("\n"),
      self.*.options.*.xhtml_out => self.*.lit("<br />\n"),
      true => self.*.lit("<br>\n")
    )
  ),

  html_inline : (fn(self: *(Self), start: i32, end: i32) -> unit)(
    if((self.*.img_nest > i32(0)), {
      // Inside image alt text — render HTML tags as escaped text
      escape_html_buf((&self.*.buf), self.*.src_ptr, start, end);
    }, {
      self.*.raw(start, end);
    })
  ),

  // Entity: decode and emit
  entity : (fn(self: *(Self), start: i32, end: i32) -> unit)({
    // Check if it's a numeric entity: &#123; or &#x41;
    if(((end - start) >= i32(4)), {
      (c1 : i32) = i32((self.*.src_ptr &+ usize((start + i32(1)))).*);
      if((c1 == i32(0x23)), {
        (c2 : i32) = i32((self.*.src_ptr &+ usize((start + i32(2)))).*);
        if(((c2 == i32(0x78)) || (c2 == i32(0x58))), {
          // Hex: &#xHHHH;
          (code : i32) = i32(0);
          (p : i32) = (start + i32(3));
          while (p < (end - i32(1))), {
            (d : i32) = i32((self.*.src_ptr &+ usize(p)).*);
            code = (code * i32(16));
            cond(
              ((d >= i32(0x30)) && (d <= i32(0x39))) => { code = (code + (d - i32(0x30))); },
              ((d >= i32(0x41)) && (d <= i32(0x46))) => { code = (code + ((d - i32(0x41)) + i32(10))); },
              ((d >= i32(0x61)) && (d <= i32(0x66))) => { code = (code + ((d - i32(0x61)) + i32(10))); },
              true => ()
            );
            p = (p + i32(1));
          };
          _emit_code_point((&self.*.buf), code);
          return ();
        }, {
          // Decimal: &#DDD;
          (code : i32) = i32(0);
          (p : i32) = (start + i32(2));
          while (p < (end - i32(1))), {
            (d : i32) = i32((self.*.src_ptr &+ usize(p)).*);
            code = ((code * i32(10)) + (d - i32(0x30)));
            p = (p + i32(1));
          };
          _emit_code_point((&self.*.buf), code);
          return ();
        });
      });
    });
    // Named entity — decode into temp buffer then HTML-escape into output
    // Entity format: &name; — name starts at start+1, ends at end-1
    (name_ptr : *(u8)) = (self.*.src_ptr &+ usize((start + i32(1))));
    (name_len : i32) = ((end - start) - i32(2));
    self.*._entity_buf.clear();
    if(decode_named_entity(name_ptr, name_len, (&self.*._entity_buf)), {
      // HTML-escape the decoded bytes
      match(self.*._entity_buf.ptr(),
        .Some(p) => escape_html_buf((&self.*.buf), p, i32(0), i32(self.*._entity_buf.len())),
        .None => ()
      );
    }, {
      // Unknown entity — pass through as-is
      self.*.raw(start, end);
    });
  }),

  // Newline in tight paragraph (hidden paragraph open/close)
  hidden_paragraph_open : (fn(self: *(Self)) -> unit)(
    ()
  ),

  hidden_paragraph_close : (fn(self: *(Self)) -> unit)(
    ()
  ),

  // Get current buffer position (for list tight paragraph removal)
  buf_pos : (fn(self: *(Self)) -> usize)(
    self.*.buf.len()
  ),

  // Remove <p> and </p>\n from buffer starting at `from_pos`.
  // Only removes direct-child paragraphs of list items (at the correct nesting level).
  // Tracks nesting depth so paragraphs inside blockquotes/sublists are preserved.
  // Uses in-place compaction: two-pointer scan over [from_pos, end) only.
  mark_tight_paragraphs : (fn(self: *(Self), from_pos: usize) -> unit)({
    (src_buf : *(ArrayList(u8))) = (&self.*.buf);
    (total : usize) = src_buf.*.len();
    if((total <= from_pos), { return (); });

    (maybe_ptr : Option(*(u8))) = src_buf.*.ptr();
    if(maybe_ptr.is_none(), { return (); });
    (s : *(u8)) = maybe_ptr.unwrap();

    // In-place compaction: read from `ri`, write to `wi`, both start at from_pos
    (ri : usize) = from_pos;
    (wi : usize) = from_pos;
    (depth : i32) = i32(0);

    while (ri < total), {
      (ch : u8) = (s &+ ri).*;
      (remaining : usize) = (total - ri);

      if((ch == u8(0x3C)), {
        // --- Depth tracking tags (copy in-place) ---

        // </blockquote>\n = 14 bytes: 0x3C 2F 62 6C 6F 63 6B 71 75 6F 74 65 3E 0A
        if(((remaining >= usize(14)) &&
            (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x62)) &&
              (((s &+ (ri + usize(3))).* == u8(0x6C)) &&
               (((s &+ (ri + usize(4))).* == u8(0x6F)) &&
                (((s &+ (ri + usize(5))).* == u8(0x63)) &&
                 (((s &+ (ri + usize(6))).* == u8(0x6B)) &&
                  (((s &+ (ri + usize(7))).* == u8(0x71)) &&
                   (((s &+ (ri + usize(8))).* == u8(0x75)) &&
                    (((s &+ (ri + usize(9))).* == u8(0x6F)) &&
                     (((s &+ (ri + usize(10))).* == u8(0x74)) &&
                      (((s &+ (ri + usize(11))).* == u8(0x65)) &&
                       ((s &+ (ri + usize(12))).* == u8(0x3E)))))))))))))), {
          depth = (depth - i32(1));
          _memmove_inline(s, wi, ri, usize(14));
          ri = (ri + usize(14));
          wi = (wi + usize(14));
        }, if(((remaining >= usize(13)) &&
            (((s &+ (ri + usize(1))).* == u8(0x62)) &&
             (((s &+ (ri + usize(2))).* == u8(0x6C)) &&
              (((s &+ (ri + usize(3))).* == u8(0x6F)) &&
               (((s &+ (ri + usize(4))).* == u8(0x63)) &&
                (((s &+ (ri + usize(5))).* == u8(0x6B)) &&
                 (((s &+ (ri + usize(6))).* == u8(0x71)) &&
                  (((s &+ (ri + usize(7))).* == u8(0x75)) &&
                   (((s &+ (ri + usize(8))).* == u8(0x6F)) &&
                    (((s &+ (ri + usize(9))).* == u8(0x74)) &&
                     (((s &+ (ri + usize(10))).* == u8(0x65)) &&
                      ((s &+ (ri + usize(11))).* == u8(0x3E))))))))))))), {
          // <blockquote>\n
          depth = (depth + i32(1));
          _memmove_inline(s, wi, ri, usize(13));
          ri = (ri + usize(13));
          wi = (wi + usize(13));
        }, if(((remaining >= usize(5)) &&
            (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x6F)) &&
              (((s &+ (ri + usize(3))).* == u8(0x6C)) &&
               ((s &+ (ri + usize(4))).* == u8(0x3E)))))), {
          // </ol>
          depth = (depth - i32(1));
          _memmove_inline(s, wi, ri, usize(5));
          ri = (ri + usize(5));
          wi = (wi + usize(5));
        }, if(((remaining >= usize(5)) &&
            (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x75)) &&
              (((s &+ (ri + usize(3))).* == u8(0x6C)) &&
               ((s &+ (ri + usize(4))).* == u8(0x3E)))))), {
          // </ul>
          depth = (depth - i32(1));
          _memmove_inline(s, wi, ri, usize(5));
          ri = (ri + usize(5));
          wi = (wi + usize(5));
        }, if(((remaining >= usize(4)) &&
            (((s &+ (ri + usize(1))).* == u8(0x6F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x6C)) &&
              ((s &+ (ri + usize(3))).* == u8(0x3E))))), {
          // <ol>
          depth = (depth + i32(1));
          _memmove_inline(s, wi, ri, usize(4));
          ri = (ri + usize(4));
          wi = (wi + usize(4));
        }, if(((remaining >= usize(4)) &&
            (((s &+ (ri + usize(1))).* == u8(0x75)) &&
             (((s &+ (ri + usize(2))).* == u8(0x6C)) &&
              ((s &+ (ri + usize(3))).* == u8(0x3E))))), {
          // <ul>
          depth = (depth + i32(1));
          _memmove_inline(s, wi, ri, usize(4));
          ri = (ri + usize(4));
          wi = (wi + usize(4));
        }, if(((remaining >= usize(6)) &&
            (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x70)) &&
              (((s &+ (ri + usize(3))).* == u8(0x72)) &&
               (((s &+ (ri + usize(4))).* == u8(0x65)) &&
                ((s &+ (ri + usize(5))).* == u8(0x3E))))))), {
          // </pre>
          depth = (depth - i32(1));
          _memmove_inline(s, wi, ri, usize(6));
          ri = (ri + usize(6));
          wi = (wi + usize(6));
        }, if(((remaining >= usize(5)) &&
            (((s &+ (ri + usize(1))).* == u8(0x70)) &&
             (((s &+ (ri + usize(2))).* == u8(0x72)) &&
              (((s &+ (ri + usize(3))).* == u8(0x65)) &&
               ((s &+ (ri + usize(4))).* == u8(0x3E)))))), {
          // <pre>
          depth = (depth + i32(1));
          _memmove_inline(s, wi, ri, usize(5));
          ri = (ri + usize(5));
          wi = (wi + usize(5));
        }, if(((remaining >= usize(14)) &&
            (((s &+ (ri + usize(1))).* == u8(0x6F)) &&
             (((s &+ (ri + usize(2))).* == u8(0x6C)) &&
              (((s &+ (ri + usize(3))).* == u8(0x20)) &&
               (((s &+ (ri + usize(4))).* == u8(0x73)) &&
                ((s &+ (ri + usize(5))).* == u8(0x74))))))), {
          // <ol start=... — increment depth
          depth = (depth + i32(1));
          (s &+ wi).* = ch;
          ri = (ri + usize(1));
          wi = (wi + usize(1));
        }, {
          // --- Paragraph removal at depth 0 ---

          // Check for </p>\n</li> (10 bytes) — replace with just </li> (5 bytes)
          if((((depth == i32(0)) && (remaining >= usize(10))) &&
              (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
               (((s &+ (ri + usize(2))).* == u8(0x70)) &&
                (((s &+ (ri + usize(3))).* == u8(0x3E)) &&
                 (((s &+ (ri + usize(4))).* == u8(0x0A)) &&
                  (((s &+ (ri + usize(5))).* == u8(0x3C)) &&
                   (((s &+ (ri + usize(6))).* == u8(0x2F)) &&
                    (((s &+ (ri + usize(7))).* == u8(0x6C)) &&
                     (((s &+ (ri + usize(8))).* == u8(0x69)) &&
                      ((s &+ (ri + usize(9))).* == u8(0x3E))))))))))), {
            // Copy </li> (from ri+5, 5 bytes)
            _memmove_inline(s, wi, (ri + usize(5)), usize(5));
            ri = (ri + usize(10));
            wi = (wi + usize(5));
          }, if((((depth == i32(0)) && (remaining >= usize(5))) &&
              (((s &+ (ri + usize(1))).* == u8(0x2F)) &&
               (((s &+ (ri + usize(2))).* == u8(0x70)) &&
                (((s &+ (ri + usize(3))).* == u8(0x3E)) &&
                 ((s &+ (ri + usize(4))).* == u8(0x0A)))))), {
            // </p>\n → just \n
            (s &+ wi).* = u8(0x0A);
            ri = (ri + usize(5));
            wi = (wi + usize(1));
          }, {
            // Not a special tag — copy byte
            (s &+ wi).* = ch;
            ri = (ri + usize(1));
            wi = (wi + usize(1));
          }));
        })))))))))
      }, if((ch == u8(0x0A)), {
        // Check for \n<p> at depth 0
        if((((depth == i32(0)) && (remaining >= usize(4))) &&
            (((s &+ (ri + usize(1))).* == u8(0x3C)) &&
             (((s &+ (ri + usize(2))).* == u8(0x70)) &&
              ((s &+ (ri + usize(3))).* == u8(0x3E))))), {
          // \n<p> at depth 0
          // Only skip the \n when previous output ends with <li>
          if(((wi >= usize(4)) &&
              (((s &+ (wi - usize(4))).* == u8(0x3C)) &&
               (((s &+ (wi - usize(3))).* == u8(0x6C)) &&
                (((s &+ (wi - usize(2))).* == u8(0x69)) &&
                 ((s &+ (wi - usize(1))).* == u8(0x3E)))))), {
            // After <li>: skip \n<p> entirely
            ri = (ri + usize(4));
          }, {
            // After other content: keep \n, skip <p>
            (s &+ wi).* = u8(0x0A);
            ri = (ri + usize(4));
            wi = (wi + usize(1));
          });
        }, {
          // Check for empty tight item: output ends with <li> and next is \n</li>
          if(((((depth == i32(0)) && (wi >= usize(4))) &&
              (remaining >= usize(6))) &&
               (((s &+ (wi - usize(4))).* == u8(0x3C)) &&
                (((s &+ (wi - usize(3))).* == u8(0x6C)) &&
                 (((s &+ (wi - usize(2))).* == u8(0x69)) &&
                  (((s &+ (wi - usize(1))).* == u8(0x3E)) &&
                   (((s &+ (ri + usize(1))).* == u8(0x3C)) &&
                    (((s &+ (ri + usize(2))).* == u8(0x2F)) &&
                     (((s &+ (ri + usize(3))).* == u8(0x6C)) &&
                      (((s &+ (ri + usize(4))).* == u8(0x69)) &&
                       ((s &+ (ri + usize(5))).* == u8(0x3E))))))))))), {
            // Skip \n for empty tight item
            ri = (ri + usize(1));
          }, {
            (s &+ wi).* = ch;
            ri = (ri + usize(1));
            wi = (wi + usize(1));
          });
        });
      }, {
        // Default: copy byte
        (s &+ wi).* = ch;
        ri = (ri + usize(1));
        wi = (wi + usize(1));
      }));
    };

    // Truncate buffer to compacted size
    src_buf.*.set_len(wi);
  })
);

export HtmlRenderer;
